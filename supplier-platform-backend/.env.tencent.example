# Server
NODE_ENV=production
PORT=3001
FRONTEND_ORIGIN=https://your-frontend-domain.example.com
EXTERNAL_API_SECRET=replace-with-a-long-random-secret

# Tencent Cloud PostgreSQL / TDSQL-C PostgreSQL
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Prisma Studio
# Run locally only: npm run prisma:studio

# JWT auth that will replace Supabase Auth later.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h
PASSWORD_RESET_TOKEN_EXPIRES_IN=15m

# Tencent Cloud COS
TENCENT_COS_SECRET_ID=replace-with-secret-id
TENCENT_COS_SECRET_KEY=replace-with-secret-key
TENCENT_COS_BUCKET=your-bucket-name-1250000000
TENCENT_COS_REGION=ap-shanghai
TENCENT_COS_PUBLIC_BASE_URL=https://your-bucket-name-1250000000.cos.ap-shanghai.myqcloud.com
TENCENT_COS_UPLOAD_PREFIX=uploads
TENCENT_COS_SIGN_EXPIRES_SECONDS=600

# Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=no-reply@example.com

# Current Supabase values remain required until the endpoint-by-endpoint migration is complete.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-current-service-role-key
